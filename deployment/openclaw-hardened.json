{
  // Hardened OpenClaw configuration baseline.
  // Start here and relax settings only as needed.

  gateway: {
    mode: "local",
    bind: "loopback",
    auth: {
      mode: "token",
      // Generate with: openssl rand -hex 32
      token: "CHANGE_ME"
    }
  },

  session: {
    // Isolate DMs per sender so conversations do not leak across users.
    dmScope: "per-channel-peer"
  },

  agents: {
    defaults: {
      model: {
        primary: "anthropic/claude-sonnet-4-5"
      },
      heartbeat: {
        every: "30m",
        target: "last",
        lightContext: true
      }
    }
  },

  tools: {
    // "messaging" profile: enables message tools, disables heavy automation.
    profile: "messaging",
    deny: ["group:automation", "group:runtime", "group:fs", "sessions_spawn"],
    fs: {
      workspaceOnly: true
    },
    exec: {
      security: "deny",
      ask: "always"
    },
    elevated: {
      enabled: false
    }
  },

  channels: {
    telegram: {
      enabled: true,
      // DM pairing: unknown senders get a code they must share for approval.
      dmPolicy: "pairing",
      groups: {
        "*": {
          requireMention: true
        }
      }
    }
  }
}
