# OpenClaw deployment environment variables
#
# Copy this file to .env and fill in your values:
#   cp .env.template .env
#
# Then edit .env (it is gitignored. Never commit real secrets).
#
# Env-source precedence (highest to lowest):
#   1. process env (values exported in your shell)
#   2. ./.env (this file, after copying)
#   3. ~/.openclaw/.env (user-global fallback)
#   4. openclaw.json `env` block (lowest)
#
# Direct config keys in openclaw.json (e.g., gateway.auth.token, channel
# tokens) are resolved separately and often take precedence over env fallbacks.

# =============================================================================
# Gateway config (required for any deployment beyond loopback)
# =============================================================================

# Docker image tag. Use "openclaw:local" if building locally, or a registry tag.
OPENCLAW_IMAGE=openclaw:latest

# Strong random token. Required when binding beyond loopback.
# Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=

# Bind interface: "loopback" (only this machine), "lan" (LAN-accessible),
# or a specific IP. Recommended: "loopback" + Tailscale or SSH tunnel.
OPENCLAW_GATEWAY_BIND=lan

# Port the gateway listens on (inside the container).
OPENCLAW_GATEWAY_PORT=18789

# Host paths mounted into the container.
# Default values assume running as root. Change if running under a different user.
OPENCLAW_CONFIG_DIR=/root/.openclaw
OPENCLAW_WORKSPACE_DIR=/root/.openclaw/workspace

# =============================================================================
# Companion tools (optional)
# =============================================================================

# Required only if you use the `gog` companion CLI (Gmail / Google Calendar).
# Generate with: openssl rand -hex 32
GOG_KEYRING_PASSWORD=

# =============================================================================
# Model provider API keys (set at least one)
# =============================================================================
# Uncomment and fill in the providers you actually use.

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...

# =============================================================================
# Messaging channel tokens (optional)
# =============================================================================
# Uncomment for each channel you enable. Tokens come from each platform's
# bot-setup flow (e.g., BotFather for Telegram, Discord developer portal, etc.).

# TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# DISCORD_BOT_TOKEN=...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# Multi-agent variant (Demo 7): two named bot tokens, one per agent.
# Only uncomment these if you are running multi-agent/openclaw.example.json5.
# Single-agent setups use TELEGRAM_BOT_TOKEN above instead.
# ALFRED_BOT_TOKEN=123456:ABCDEF...
# CODER_BOT_TOKEN=123456:ABCDEF...

# =============================================================================
# Tools and search (optional)
# =============================================================================
# Used by web-search and scraping skills if installed.

# BRAVE_API_KEY=...
# PERPLEXITY_API_KEY=pplx-...
# FIRECRAWL_API_KEY=...
