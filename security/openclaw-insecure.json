{
  // DELIBERATELY INSECURE configuration for demonstration purposes.
  // DO NOT use this in production. This config is used in Module 4
  // to show what happens when an agent has no guardrails.

  gateway: {
    mode: "local",
    bind: "lan",
    auth: {
      mode: "token",
      token: "demo-insecure-token"
    }
  },

  agents: {
    defaults: {
      model: {
        primary: "anthropic/claude-sonnet-4-5"
      },
      sandbox: {
        mode: "off"
      }
    }
  },

  tools: {
    // All tools available, no restrictions.
    exec: {
      security: "allow"
    },
    elevated: {
      enabled: true
    },
    fs: {
      workspaceOnly: false
    }
  },

  channels: {
    telegram: {
      enabled: true,
      // Open to everyone. No pairing, no allowlist.
      dmPolicy: "open",
      allowFrom: ["*"],
      groups: {
        "*": {
          requireMention: false
        }
      }
    }
  }
}
