{
  // HARDENED configuration: the "after" state for the Module 4 security demo.
  // Compare with openclaw-insecure.json to see what changed.

  gateway: {
    mode: "local",
    bind: "loopback",                         // Changed: loopback only (was: lan)
    auth: {
      mode: "token",
      token: "CHANGE_ME"                      // Changed: strong random token
    }
  },

  session: {
    dmScope: "per-channel-peer"               // Added: isolate sessions per sender
  },

  agents: {
    defaults: {
      model: {
        primary: "anthropic/claude-sonnet-4-5"
      },
      sandbox: {
        mode: "non-main"                      // Changed: sandbox non-main sessions (was: off)
      }
    }
  },

  tools: {
    profile: "messaging",                     // Added: restrict to messaging tool profile
    deny: [                                   // Added: deny dangerous tool groups
      "group:automation",
      "group:runtime",
      "sessions_spawn"
    ],
    exec: {
      security: "deny",                       // Changed: deny exec by default (was: allow)
      ask: "always"                           // Changed: always ask if exec is needed
    },
    elevated: {
      enabled: false                          // Changed: no elevated tools (was: true)
    },
    fs: {
      workspaceOnly: true                     // Changed: restrict to workspace (was: false)
    }
  },

  channels: {
    telegram: {
      enabled: true,
      dmPolicy: "pairing",                    // Changed: require pairing (was: open)
      // Removed: allowFrom: ["*"]
      groups: {
        "*": {
          requireMention: true                // Changed: require mention (was: false)
        }
      }
    }
  }
}
