# Instructor-only demo runbooks (not shared with students)
demo_runbooks/

# Instructor-only skill: course-prep is for resetting/backfilling Alfred's
# workspace before a teaching session. Not a teaching artifact.
workspaces/personal-assistant/skills/course-prep/

# Instructor-only skill: hn-digest is the live target for the Module 4 security
# demo (exec approvals, allowlist hardening). Lives only on the demo VPS.
workspaces/personal-assistant/skills/hn-digest/

# OpenClaw runtime state (generated by the agent, not source)
.openclaw/
**/heartbeat-state.json

# Environment files with real secrets
.env
*.env.local

# OS files
.DS_Store
Thumbs.db

# Python runtime artifacts (from running scripts like rental-search)
__pycache__/
*.pyc
