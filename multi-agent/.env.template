# Multi-agent setup environment variables.
# Copy this file to .env and fill in the values.

# Two Telegram bot tokens.
# Create bots via @BotFather on Telegram:
#   /newbot -> follow prompts -> copy the token
# Suggested bot names: alfred_<yourhandle>_bot and coder_<yourhandle>_bot
ALFRED_BOT_TOKEN=
CODER_BOT_TOKEN=

# LLM provider key. OpenRouter is the default in openclaw.example.json5,
# but you can swap the provider in the config if you prefer Anthropic or OpenAI direct.
OPENROUTER_API_KEY=

# Your numeric Telegram user ID (not @username).
# Find it by DM'ing @userinfobot on Telegram.
# Used by the pairing flow to grant access to your own bots.
TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# Optional: GitHub PAT for the coder agent's create-pr / review-code skills.
# -----------------------------------------------------------------------------
# Needed only if you want to reproduce the Demo 7 live-fire (coder branches,
# commits, pushes, opens a PR via `gh pr create`). See README.md section
# "Beyond chat: git push and PR creation" for the full setup.
#
# Classic PAT with `repo` scope, from a dedicated bot GitHub account that is
# a collaborator on the target repo. Cross-account fine-grained PATs require
# resource-owner approval, which is extra friction — classic + `repo` is
# simpler for a single-repo bot account.
# GH_TOKEN=ghp_...
