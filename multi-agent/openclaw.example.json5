{
  // Multi-agent gateway config (Demo 7 reference).
  //
  // Two agents on one gateway, each bound to its own Telegram bot:
  //   - alfred: personal assistant persona (personal-assistant workspace) on @alfred_bot
  //   - coder:  engineer persona (coding-agent workspace) on @coder_bot
  //
  // Before using:
  //   1. Copy ../workspaces/personal-assistant to ~/.openclaw/workspace-alfred
  //   2. Copy ../workspaces/coding-agent to ~/.openclaw/workspace-coder
  //   3. Create two Telegram bots via @BotFather, put tokens in .env
  //   4. Point OpenClaw at this config (or merge into ~/.openclaw/openclaw.json)
  //   5. DM each bot to get a pairing code, then approve from the host with
  //      `openclaw pairing approve telegram <CODE>` (or via `docker compose
  //      exec openclaw-gateway openclaw pairing approve telegram <CODE>`).
  //
  // See README.md in this folder for the full walkthrough.

  agents: {
    // Shared defaults: model, providers, heartbeat. Agents inherit these unless
    // overridden per-agent under agents.list[].
    defaults: {
      models: {
        "openrouter/auto": { alias: "OpenRouter" },
        "openrouter/anthropic/claude-sonnet-4.6": {},
      },
      model: {
        primary: "openrouter/anthropic/claude-sonnet-4.6",
        fallbacks: ["openrouter/auto"],
      },
    },

    // One entry per agent. Each agent gets its own workspace, auth, sessions.
    // Per-agent blocks below override the defaults above. They can narrow
    // or redirect, but cannot expand beyond the global trust boundary.
    list: [
      {
        id: "alfred",
        workspace: "~/.openclaw/workspace-alfred",
        // No overrides; alfred inherits everything from defaults.
      },
      {
        id: "coder",
        workspace: "~/.openclaw/workspace-coder",

        // Turn heartbeat off for this agent; coder acts only when DM'd.
        heartbeat: { every: "0m" },

        // Swap to a coding-optimized model. Kimi K2.6 is strong at code,
        // cheap per token, and has wide context. Fallback stays on auto.
        model: {
          primary: "openrouter/moonshotai/kimi-k2.6",
          fallbacks: ["openrouter/auto"],
        },

        // DEMO-SPECIFIC exec setting: full-autopilot so the coder can
        // branch / commit / push / gh pr create without approval prompts.
        // For production use, prefer:
        //   tools: { exec: { security: "allowlist", ask: "on-miss" } }
        // and widen the allowlist as the agent proves itself on routine
        // commands. With security: "full" the agent can run any shell
        // command the container user can run, so the real sandbox here
        // is the Docker container the gateway runs in (per the deployment
        // guide). Do not use security: "full" if the gateway is running
        // directly on a host without container isolation.
        tools: { exec: { security: "full", ask: "off" } },
      },
    ],
  },

  // Routing rules. Inbound messages are matched top-down; first match wins.
  // Here: messages arriving on the 'alfred' Telegram account go to the alfred
  // agent; messages on the 'coder' account go to the coder agent.
  bindings: [
    {
      agentId: "alfred",
      match: { channel: "telegram", accountId: "alfred" },
    },
    {
      agentId: "coder",
      match: { channel: "telegram", accountId: "coder" },
    },
  ],

  channels: {
    telegram: {
      enabled: true,
      // Two separate Telegram bot accounts, keyed by accountId.
      // accountId values match the bindings above.
      accounts: {
        alfred: {
          botToken: "${ALFRED_BOT_TOKEN}",
          dmPolicy: "pairing",
        },
        coder: {
          botToken: "${CODER_BOT_TOKEN}",
          dmPolicy: "pairing",
        },
      },
    },
  },
}
